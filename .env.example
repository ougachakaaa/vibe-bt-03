# App
APP__NAME=vibe-bt
APP__ENV=development
APP__DEBUG=true
APP__TIMEZONE=Asia/Shanghai

# Database
DATABASE__DRIVER=postgresql+psycopg
DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__USER=postgres
DATABASE__PASSWORD=
DATABASE__NAME=vibe_bt
DATABASE__ECHO=false

# Data source
DATASOURCE__PRIMARY_STOCK_DATASOURCE=tushare
DATASOURCE__TUSHARE_TOKEN=
DATASOURCE__TIMEOUT_SECONDS=30
DATASOURCE__RETRY_TIMES=3

# Ingestion
INGESTION__STOCK_BAR_START_DATE=2010-01-01
INGESTION__STOCK_BAR_BATCH_SIZE=500
INGESTION__RETRY_TIMES=3
INGESTION__DRY_RUN=false

# Logging
LOGGING__LEVEL=INFO
LOGGING__TO_FILE=true
LOGGING__FILE=./logs/app.log

# Paths
PATHS__DATA_DIR=./data
PATHS__LOG_DIR=./logs
PATHS__CACHE_DIR=./cache
